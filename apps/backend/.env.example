# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# In dev the frontend runs on :5173 (Vite). In prod replace with your domain.
CORS_ORIGIN=http://localhost:5173

# ── Better Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001

# ── Turso / libSQL ───────────────────────────────────────────────────────────
# Local dev: use a local SQLite file via libSQL
TURSO_DATABASE_URL=file:local.db
# Remote Turso: use your Turso database URL and auth token
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Discord OAuth ────────────────────────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/discord
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Bot username WITHOUT the @ prefix
TELEGRAM_BOT_USERNAME=your_bot_username
