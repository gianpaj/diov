# Frontend connection settings for the SpacetimeDB-backed client.
# Default local server URL is :3000. If your local SpacetimeDB instance is
# running on another port, update this value accordingly.
VITE_SPACETIMEDB_HOST=ws://127.0.0.1:3002
VITE_SPACETIMEDB_DB_NAME=battle-circles

# ── Auth backend ─────────────────────────────────────────────────────────────
# URL of the Hono backend that runs Better Auth
VITE_BETTER_AUTH_URL=http://localhost:3001
