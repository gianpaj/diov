SPACETIMEDB_HOST=ws://127.0.0.1:3002
SPACETIMEDB_DB_NAME=battle-circles

BOT_PLAYER_NAME=Bot Alpha
BOT_ROOM_ID=guest-global

# Options: lobby-fill, benchmark, bridge
BOT_POLICY=lobby-fill

# Used when BOT_POLICY=bridge
BOT_POLICY_SOCKET_PATH=/tmp/battle-circles-policy.sock

# Options: structured, packed
BOT_POLICY_OBSERVATION_FORMAT=structured

BOT_VIEWPORT_WIDTH=1280
BOT_VIEWPORT_HEIGHT=720
BOT_CAMERA_SMOOTHING=0.1
BOT_DECISION_DEBOUNCE_MS=40

# Optional newline-delimited JSON export for replay/training traces
BOT_TRACE_PATH=

# Run more than one bot client in a single process
BOT_COUNT=1
